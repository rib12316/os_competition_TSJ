# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# ===== uv / venv (隔离环境位于仓库根目录) =====
.venv/
venv/
env/

# ===== 第三方克隆代码库（仅保留版本清单） =====
third_party/*
!third_party/README.md
!third_party/VERSIONS.md

# ===== 实验日志原始数据（仅保留 README/结构说明） =====
# 命名规范见 dev-guide/log-naming-convention.md
logs/*
!logs/README.md
!logs/.gitkeep

# ===== 模型权重 / 大体积二进制（仅保留 models/README.md 清单） =====
models/*
!models/README.md
*.safetensors
*.bin
*.gguf
*.pt
*.onnx

# ===== 缓存 =====
.cache/

# ===== IDE / OS =====
.idea/
.vscode/
.ipynb_checkpoints/
.DS_Store
*.swp

# ===== mkdocs 构建产物 =====
site/
